class Solution(object):
    def differenceOfSum(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        esum=sum(nums)
        
        dsum=0
        for i in nums:
            while(i>0):
                dsum+=i%10
                i=i//10

        return abs(esum-dsum)
        
