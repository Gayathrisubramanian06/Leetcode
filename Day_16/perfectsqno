class Solution(object):
    def isPerfectSquare(self, num):
        """
        :type num: int
        :rtype: bool
        """
        l=1
        high=num
        while(l<high):
            mid=(l+high)/2
            if mid*mid==num:
                return True
                break
            elif mid*mid>num:
                high=mid-1
            else:
                l=mid+1
        return False
                
