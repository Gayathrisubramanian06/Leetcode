class Solution(object):
    def sumOfTheDigitsOfHarshadNumber(self, x):
        """
        :type x: int
        :rtype: int
        """
        sum=0
        n=x
        if n==0:
            return -1
        while n>0:
            sum+=n%10
            n=n//10

        if x%sum==0:
            return sum
        else : 
            return -1
